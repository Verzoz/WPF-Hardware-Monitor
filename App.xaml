<Application x:Class="Hardware_Monitor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Hardware_Monitor"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        
        <!-- Definizione di tutte le variabili di cui ho bisogno -->

        <FontFamily x:Key="FontUsato">Palatino Linotype</FontFamily>

        <SolidColorBrush x:Key="SfondoFinestra" Color="#1E1E1E" />

        <SolidColorBrush x:Key="SfondoRiquadri" Color="#2D2D30" />

        <SolidColorBrush x:Key="SfondoBottoni" Color="#3E3E42" />

        <SolidColorBrush x:Key="ColoreAccento" Color="#007ACC" />

        <SolidColorBrush x:Key="TestoPrincipale" Color="#FFFFFF" />

        <SolidColorBrush x:Key="TestoSecondario" Color="#9A9A9A" />


        <Style x:Key="TitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontUsato}" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <!-- STILE BOTTONI -->
        <Style x:Key="StyleBottoni" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SfondoBottoni}" />
            <Setter Property="Foreground" Value="{StaticResource TestoPrincipale}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontFamily" Value="{StaticResource FontUsato}"/>

            <Setter Property="Padding" Value="15,10" />
            <Setter Property="Margin" Value="0,6" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BordoInterno" 
                        Background="{TemplateBinding Background}" 
                        CornerRadius="6" 
                        Padding="{TemplateBinding Padding}">

                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BordoInterno" Property="Background" Value="{StaticResource ColoreAccento}" />
                                <Setter Property="Cursor" Value="Hand" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BordoInterno" Property="Background" Value="#005999" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>



        <!-- STILE TESTI PRINCIPALI -->
        <Style x:Key="StyleTestoPrincipale" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontUsato}" />
            <Setter Property="Foreground" Value="{StaticResource TestoPrincipale}" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <!-- STILE TESTI SECONDARI -->
        <Style x:Key="StyleTestoSecondario" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontUsato}" />
            <Setter Property="Foreground" Value="{StaticResource TestoSecondario}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>




    </Application.Resources>
</Application>
    
    


<Window x:Class="Hardware_Monitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hardware_Monitor"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True">

    <Border Background="#1E1E1E" 
        CornerRadius="12" 
        ClipToBounds="True">

        <Border.Clip>
            <RectangleGeometry RadiusX="12" RadiusY="12" 
                           Rect="0,0,800,450" />
        </Border.Clip>


        <Grid Background="{StaticResource SfondoRiquadri}">
            <!--Prima Griglia generale per dividere lo spazio in due colonne: una della selezione delle schermate e un altra dei componenti all interno di una schermata-->



            <Grid.RowDefinitions>

                <RowDefinition Height="30" />

                <RowDefinition Height="*" />

            </Grid.RowDefinitions>



            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="Auto"/>
                <!-- quella relativa ai tasti per la selezione delle schermate-->

                <ColumnDefinition Width="*"/>
                <!-- Il resto -->

            </Grid.ColumnDefinitions>



            <!-- Creiamo la Riga per i comandi di chiusura e minimizzazione della finestra -->

            <Grid Grid.Row="0" 

          Grid.ColumnSpan="2"

          Background="Transparent"

          VerticalAlignment="Top"

          MouseLeftButtonDown="BarraTitolo_MouseLeftButtonDown">



                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*" />

                    <ColumnDefinition Width="Auto" />

                </Grid.ColumnDefinitions>



                <TextBlock Text="Hardware Monitor" 

                   Style="{StaticResource StyleTestoPrincipale}"/>



                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,5,10,0">

                    <Button Content="—" Click="BtnRiduci_Click" Width="30" Height="25" 

            Background="Transparent" Foreground="White" BorderThickness="0" FontSize="10"/>

                    <Button Content="✕" Click="BtnChiudi_Click" Width="30" Height="25" 

            Background="Transparent" Foreground="White" BorderThickness="0" FontSize="12" Margin="5,0,0,0"/>

                </StackPanel>



            </Grid>



            
            
            <Border Grid.Column="0" Grid.Row="1"

            Background="#252626"

            Margin="10" 

            CornerRadius="8">



                <StackPanel Grid.Column="0" 
                            Margin="10"
                            VerticalAlignment="Center">



                    <TextBlock x:Name="TestoSelezioneSchermate"
                                Text="SELEZIONE&#x0a;SCHERMATA"
                                FontSize="30"
                                Style="{StaticResource StyleTestoPrincipale}"/>



                    <Button x:Name="BtnSchermataGenerale" 

                            Content="GENERALE" 

                            Click="BtnSchermataGenerale_Click" 

                            Style="{StaticResource StyleBottoni}"/>



                    <Button x:Name="BtnSchermataCPU" 

                            Content="CPU" 

                            Click="BtnSchermataCPU_Click" 

                            Style="{StaticResource StyleBottoni}"/>



                    <Button x:Name="BtnSchermataGPU" 

                            Content="GPU" 

                            Click="BtnSchermataGPU_Click" 

                            Style="{StaticResource StyleBottoni}"/>



                    <Button x:Name="BtnSchermataRAM" 

                            Content="RAM" 

                            Click="BtnSchermataRAM_Click" 

                            Style="{StaticResource StyleBottoni}"/>



                    <Button x:Name="BtnSchermataDischi" 

                            Content="DISCHI" 

                            Click="BtnSchermataDischi_Click" 

                            Style="{StaticResource StyleBottoni}"/>



                </StackPanel>



            </Border>



            <ContentControl Grid.Column="1" Grid.Row="1"

                    x:Name="ContenitoreSegnaposto"/>
        </Grid>



    </Border>


</Window>
